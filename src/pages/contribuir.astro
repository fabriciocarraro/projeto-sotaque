---
import Base from "../layouts/Base.astro";
import MapaDialetos from "../components/MapaDialetos.astro";
import FormularioContribuicao from "../components/FormularioContribuicao.tsx";

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "1x00000000000000000000AA";
---

<Base title="Contribuir — SOTAQUE">
  <div class="mx-auto max-w-3xl px-4 py-14">
    <header>
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-verde-700">
        SOTAQUE: Speech-Oriented Training Audio for Quality Understanding and Expression
      </p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-stone-900 md:text-4xl">Contribuir com a minha voz</h1>
      <p class="mt-3 leading-relaxed text-stone-700">
        Obrigado por doar sua voz ao Projeto SOTAQUE. Antes de enviar sua contribuição, leia o
        <a href="/termo" class="font-medium text-verde-700 underline decoration-verde-600/40 underline-offset-2 hover:text-verde-800" target="_blank" rel="noopener">
          Termo de Consentimento e Aviso de Privacidade</a
        >.
      </p>
    </header>

    <div class="mt-8 rounded-xl border-l-4 border-verde-600 bg-white p-5 text-sm text-stone-700 shadow-sm">
      <p class="font-semibold text-stone-900">Resumo antes do aceite</p>
      <p class="mt-2 leading-relaxed">
        Ao enviar sua voz ao Projeto SOTAQUE, você concorda que suas gravações, transcrições e
        determinados metadados possam ser curados, publicados em dataset aberto e usados para
        treinar e avaliar tecnologias de fala, inclusive TTS. A participação é voluntária e
        restrita a maiores de 18 anos localizados no Brasil no momento da contribuição. Você pode
        retirar seu consentimento para usos futuros sob controle do Projeto, mas isso pode não
        apagar cópias já publicadas, redistribuídas ou incorporadas a modelos já treinados.
      </p>
    </div>

    <div class="mt-8 rounded-xl border border-stone-200 bg-white p-6 shadow-sm">
      <h2 class="text-sm font-semibold text-stone-900">Dialetos do português brasileiro</h2>
      <p class="mt-1 text-xs text-stone-600">
        Use a imagem como referência ao escolher seu sotaque no formulário.
      </p>
      <div class="mt-4">
        <MapaDialetos />
      </div>
    </div>

    <div class="mt-10">
      <FormularioContribuicao client:load turnstileSiteKey={turnstileSiteKey} />
    </div>
  </div>
</Base>
