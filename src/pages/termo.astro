---
import Base from "../layouts/Base.astro";
import { getEntry } from "astro:content";

const termo = await getEntry("termo", "v1");
if (!termo) throw new Error("Termo v1 não encontrado.");
const { Content } = await termo.render();
---

<Base title={`${termo.data.titulo} — SOTAQUE`}>
  <article class="mx-auto max-w-prose px-4 py-14">
    <header class="border-b border-stone-200 pb-6">
      <p class="inline-flex items-center gap-2 rounded-full bg-verde-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-verde-800">
        Versão {termo.data.versao}
      </p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-stone-900 md:text-4xl">{termo.data.titulo}</h1>
      <p class="mt-2 text-sm text-stone-600">
        SOTAQUE: {termo.data.subtitulo.replace(/^Projeto SOTAQUE\s*—\s*/, "")}
      </p>
    </header>

    <div
      class="prose prose-stone mt-8 max-w-none
             prose-headings:tracking-tight prose-headings:text-stone-900
             prose-h2:mt-10 prose-h2:text-2xl
             prose-h3:mt-6 prose-h3:text-lg
             prose-a:text-verde-700 prose-a:font-medium prose-a:no-underline hover:prose-a:text-verde-800 hover:prose-a:underline
             prose-strong:text-stone-900 prose-strong:font-semibold
             prose-li:my-0.5 prose-li:text-stone-700
             prose-p:text-stone-700 prose-p:leading-relaxed"
    >
      <Content />
    </div>

    <div class="mt-12 rounded-xl border-l-4 border-verde-600 bg-white p-5 text-sm text-stone-700 shadow-sm">
      <p class="font-semibold text-stone-900">Dúvidas ou revogação?</p>
      <p class="mt-2">
        Para dúvidas sobre privacidade, exercício de direitos ou revogação de consentimento,
        escreva para
        <a
          href="mailto:contato@fabriciocarraro.com.br"
          class="font-medium text-verde-700 underline decoration-verde-600/40 underline-offset-2 hover:text-verde-800">contato@fabriciocarraro.com.br</a
        >.
      </p>
      <p class="mt-2">
        Também é possível pedir revogação pelo
        <a href="/revogacao" class="font-medium text-verde-700 underline decoration-verde-600/40 underline-offset-2 hover:text-verde-800">formulário de revogação</a>.
      </p>
    </div>
  </article>
</Base>
