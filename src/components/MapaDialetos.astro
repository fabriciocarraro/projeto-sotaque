---
const imgSrc = "https://upload.wikimedia.org/wikipedia/commons/thumb/d/df/Dialetos_do_Brasil.svg/640px-Dialetos_do_Brasil.svg.png";
---

<figure class="rounded-lg border border-slate-200 bg-white p-3">
  <img
    src={imgSrc}
    alt="Mapa dos dialetos do português brasileiro, segundo a Wikipédia"
    class="mx-auto block w-full max-w-md"
    loading="lazy"
  />
  <figcaption class="mt-2 text-center text-xs text-slate-500">
    Mapa dos dialetos do português brasileiro.
    Fonte:
    <a
      href="https://pt.wikipedia.org/wiki/Portugu%C3%AAs_brasileiro#Dialetos_do_portugu%C3%AAs_brasileiro"
      rel="noopener"
      target="_blank"
      class="underline hover:text-slate-700">Wikipédia</a> — imagem sob licença Creative Commons.
  </figcaption>
</figure>
