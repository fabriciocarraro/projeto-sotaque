---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Projeto SOTAQUE — dataset aberto de vozes em português brasileiro." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-amarelo-100 text-stone-800 antialiased flex flex-col">
    <header class="border-b border-amarelo-300/70 bg-amarelo-50/90 backdrop-blur supports-[backdrop-filter]:bg-amarelo-50/70">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
        <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight text-stone-900" aria-label="SOTAQUE — voltar para o início">
          <img src="/logo.png" alt="" width="36" height="36" class="h-9 w-9" />
          <span class="text-lg">SOTAQUE</span>
        </a>
        <nav class="hidden items-center gap-6 text-sm text-stone-700 md:flex">
          <a href="/" class="transition hover:text-verde-700">Início</a>
          <a href="/sobre" class="transition hover:text-verde-700">Sobre</a>
          <a href="/termo" class="transition hover:text-verde-700">Termo</a>
          <a
            href="/contribuir"
            class="inline-flex items-center rounded-md bg-verde-600 px-3.5 py-1.5 font-medium text-white shadow-sm transition hover:bg-verde-700"
            >Contribuir</a
          >
        </nav>
        <a href="/contribuir" class="md:hidden inline-flex items-center rounded-md bg-verde-600 px-3 py-1.5 text-sm font-medium text-white shadow-sm hover:bg-verde-700">Contribuir</a>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-16 border-t-2 border-verde-600/80 bg-amarelo-50">
      <div class="mx-auto max-w-5xl px-4 py-10 text-sm text-stone-700">
        <div class="grid gap-8 md:grid-cols-3">
          <div>
            <p class="flex items-center gap-2 font-semibold text-stone-900">
              <img src="/logo.png" alt="" width="20" height="20" class="h-5 w-5" />
              Projeto SOTAQUE
            </p>
            <p class="mt-2 text-stone-600">Dataset aberto de vozes em português brasileiro.</p>
            <p class="mt-1 text-stone-600">Licença do dataset: CDLA-Permissive-2.0.</p>
          </div>
          <div>
            <p class="font-semibold text-stone-900">Contato</p>
            <p class="mt-2">
              <a href="mailto:contato@fabriciocarraro.com.br" class="text-verde-700 hover:text-verde-800 hover:underline">
                contato@fabriciocarraro.com.br
              </a>
            </p>
            <p class="mt-1 text-stone-600">Privacidade, direitos e revogação.</p>
          </div>
          <div>
            <p class="font-semibold text-stone-900">Código-fonte</p>
            <p class="mt-2">
              <a
                href="https://github.com/fabriciocarraro/projeto-sotaque"
                class="text-verde-700 hover:text-verde-800 hover:underline"
                rel="noopener"
                target="_blank">github.com/fabriciocarraro/projeto-sotaque</a>
            </p>
          </div>
        </div>
        <p class="mt-8 border-t border-stone-200 pt-6 text-xs text-stone-500">
          Controlador: Fabrício Carraro (pessoa natural). Este site coleta dados conforme descrito no
          <a href="/termo" class="underline hover:text-verde-700">Termo de Consentimento e Aviso de Privacidade</a>.
        </p>
      </div>
    </footer>
  </body>
</html>
